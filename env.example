# 复制为 .env（或 conf.json / config.yml 等，见 github.com/lengzhao/conf）后按需修改。
# 程序启动时会通过 conf/autoload 按顺序尝试加载第一个存在的文件：
# .env、conf.json、config.json、conf.yml、config.yml，再 ~/.oneclaw/ 下同名文件。
# 文件中出现的键会写入进程环境（与 conf.SaveToENV cover=true 行为一致：会覆盖已在环境中的同名变量）。
#
# 「关闭类」变量 ONCLAW_DISABLE_*：0 与未设置等价（功能开启）；1/true/yes 为关闭。

# -----------------------------------------------------------------------------
# OpenAI 兼容 API（openai-go 客户端）
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# 可选；自定义网关时设置，需包含 /v1/ 后缀（与测试 stub 一致）
OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# 模型与会话（默认与 session.NewEngine 一致）
# -----------------------------------------------------------------------------
ONCLAW_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# 日志（也可用 CLI：-log-level、-log-format；未设置时与下列默认值一致）
# -----------------------------------------------------------------------------
ONCLAW_LOG_LEVEL=info
ONCLAW_LOG_FORMAT=text

# -----------------------------------------------------------------------------
# 聊天传输方式（空或 auto：流式失败则回退非流式）
# -----------------------------------------------------------------------------
ONCLAW_CHAT_TRANSPORT=auto

# -----------------------------------------------------------------------------
# 记忆（文件注入 / 写入根路径等）
# -----------------------------------------------------------------------------
ONCLAW_DISABLE_MEMORY=0
# 留空则记忆根目录为 ~/.oneclaw；若写 ~/... 会按用户主目录展开（与 shell 不同，未展开时 Go 曾把 ~ 当成相对路径下的目录名）
ONCLAW_MEMORY_BASE=

ONCLAW_DISABLE_AUTO_MEMORY=0

ONCLAW_DISABLE_MEMORY_EXTRACT=0
# 工具与回合结束 assistant 回复：立即追加 JSONL；1/true/yes 关闭落盘
ONCLAW_DISABLE_TURN_LOG=0
# 留空：按日分文件 <cwd>/.oneclaw/traces/logs/YYYY/MM/YYYY-MM-DD.jsonl（与 memory daily log 同级目录风格）
# 以 .jsonl 结尾：固定单文件；否则视为目录根，写入 <根>/logs/YYYY/MM/YYYY-MM-DD.jsonl
ONCLAW_TURN_LOG_PATH=

# -----------------------------------------------------------------------------
# 自动维护（将当日 daily log 蒸馏进 MEMORY.md）
# -----------------------------------------------------------------------------
# 0 开启（默认）；1/true/yes 关闭
ONCLAW_DISABLE_AUTO_MAINTENANCE=0
# 回合后维护：非空则优先于主会话模型；留空则回落到 ONCLAW_MODEL
ONCLAW_MAINTENANCE_MODEL=
# 定时维护（cmd/maintain）：非空则优先于 ONCLAW_MAINTENANCE_MODEL
ONCLAW_MAINTENANCE_SCHEDULED_MODEL=
# 留空则沿用传入的会话 MaxTokens（默认 8192）；可显式覆盖维护 completion 的 max_completion_tokens
ONCLAW_MAINTENANCE_MAX_TOKENS=8192
ONCLAW_MAINTENANCE_MIN_LOG_BYTES=200
ONCLAW_MAINTENANCE_MAX_LOG_BYTES=24000
# cmd/maintain 默认常驻：每间隔跑一轮蒸馏；Go duration，留空=1h；0/off/false=只跑一轮（等价于 -once）
ONCLAW_MAINTAIN_INTERVAL=1h

# -----------------------------------------------------------------------------
# 上下文预算（prompt 估算字节上限与 recall 等）
# -----------------------------------------------------------------------------
ONCLAW_DISABLE_CONTEXT_BUDGET=0
ONCLAW_MAX_PROMPT_BYTES=128000
ONCLAW_MIN_TRANSCRIPT_MESSAGES=6
ONCLAW_RECALL_MAX_BYTES=12000

# -----------------------------------------------------------------------------
# REPL 入口（cmd/oneclaw）：无命令行参数，cwd=当前工作目录
# -----------------------------------------------------------------------------
# 留空：transcript 为 <cwd>/.oneclaw/transcript.json；非空则覆盖；相对路径按 cwd 解析
ONCLAW_TRANSCRIPT_PATH=
# 1/true/yes：不加载、不自动保存 transcript
ONCLAW_DISABLE_TRANSCRIPT=0
#
# 定时维护（cmd/maintain）：默认按 ONCLAW_MAINTAIN_INTERVAL 常驻循环；单次（cron）用 -once 或 ONCLAW_MAINTAIN_INTERVAL=0：
#   go run ./cmd/maintain -cwd /path/to/repo
#   go run ./cmd/maintain -cwd /path/to/repo -once
# 覆盖间隔：-interval 30m
# 模型由 ONCLAW_MAINTENANCE_SCHEDULED_MODEL / ONCLAW_MAINTENANCE_MODEL / ONCLAW_MODEL 决定。

# -----------------------------------------------------------------------------
# Memory 变更审计（append-only JSONL；亦可依赖仓库对 .oneclaw 的 git 历史）
# -----------------------------------------------------------------------------
# 1/true/yes 关闭审计落盘
ONCLAW_DISABLE_MEMORY_AUDIT=0
